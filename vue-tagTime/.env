# ========================================
# 开发环境配置
# ========================================

# API 基础地址配置
# 留空则自动根据访问地址构建（推荐）
# 例如：访问 http://localhost:5173 时，API 地址为 http://localhost:8080/api/v1
# 例如：访问 http://192.168.1.100:5173 时，API 地址为 http://192.168.1.100:8080/api/v1
VITE_API_BASE_URL=

# 如需指定固定的后端地址，取消下面的注释并修改
# VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_API_BASE_URL=http://192.168.1.100:8080/api/v1
