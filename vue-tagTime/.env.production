# ========================================
# 生产环境配置
# ========================================

# API 基础地址配置
# 
# 方式 1：自动检测（推荐，前后端同域名部署）
# 留空，前端会根据访问地址自动构建 API 地址
VITE_API_BASE_URL=

# 方式 2：指定完整的后端 API 地址（前后端分离部署）
# 取消下面的注释并修改为实际的后端地址
# VITE_API_BASE_URL=https://api.your-domain.com/api/v1
# VITE_API_BASE_URL=http://your-server-ip:8080/api/v1

# 注意：
# 1. 如果使用 Nginx 反向代理，建议留空使用自动检测
# 2. 如果前后端不同域名，需要配置完整的后端地址
# 3. 生产环境建议使用 HTTPS
