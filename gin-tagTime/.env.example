# ========================================
# 服务器配置
# ========================================
# 服务器监听地址（0.0.0.0 表示监听所有网络接口）
SERVER_HOST=0.0.0.0
# 服务器端口
SERVER_PORT=8080
# Gin 运行模式: debug, release, test
GIN_MODE=release

# ========================================
# CORS 跨域配置
# ========================================
# 允许的前端源地址，多个用逗号分隔
# 开发环境示例: http://localhost:5173,http://192.168.1.100:5173
# 生产环境示例: https://your-domain.com,https://www.your-domain.com
# 留空则允许所有源（仅用于开发环境）
CORS_ALLOWED_ORIGINS=

# ========================================
# 数据库配置
# ========================================
DB_USER=root
DB_PASSWORD=Root@1234
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tagtime

# ========================================
# Redis配置（用于缓存和限流）
# ========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# AI服务配置
# ========================================
# 支持的提供商: openai, zhipu, deepseek
AI_PROVIDER=deepseek
AI_API_KEY=sk-7a814a87c62c42d69befbfef132be406

# DeepSeek配置（推荐）
AI_ENDPOINT=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-reasoner

# OpenAI配置（备选）
# AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-3.5-turbo

# 智谱AI配置（备选）
# AI_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
# AI_MODEL=glm-4

AI_TIMEOUT=30s
AI_DAILY_LIMIT=3
AI_CACHE_EXPIRE=10m
AI_GLOBAL_RATE_LIMIT=10
