# ========================================
# 生产环境配置模板
# ========================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下面的配置为实际的生产环境值
# 3. 确保 .env 文件不要提交到版本控制系统

# ========================================
# 服务器配置
# ========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release

# ========================================
# CORS 跨域配置
# ========================================
# 生产环境必须配置具体的前端域名，多个用逗号分隔
# 示例: https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ========================================
# 数据库配置
# ========================================
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tagtime

# ========================================
# Redis配置
# ========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# ========================================
# AI服务配置
# ========================================
AI_PROVIDER=deepseek
AI_API_KEY=sk-7a814a87c62c42d69befbfef132be406
AI_ENDPOINT=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-reasoner
AI_TIMEOUT=30s
AI_DAILY_LIMIT=3
AI_CACHE_EXPIRE=10m
AI_GLOBAL_RATE_LIMIT=10
